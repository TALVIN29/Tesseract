# ============================================================
# PROJECT TESSERACT — Environment Variable Reference
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ------------------------------------------------------------
# INNER CUBE (Fastify API)
# ------------------------------------------------------------
CUBE_PORT=3100

# PostgreSQL connection for Audit Ledger (postgres-cube container)
CUBE_DB_URL=postgresql://cube_api:CHANGE_ME@localhost:5433/tesseract_cube

# Redis connection (shared with Planes)
CUBE_REDIS_URL=redis://localhost:6379

# JWT secret for Plane-to-Cube service account tokens
CUBE_JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# mTLS: path to the CA cert that issued the Plane client certificates
CUBE_MTLS_CA_CERT_PATH=./infra/certs/planes-ca.crt

# Path to the /rules Git repo (mounted into cube container)
CUBE_RULES_PATH=/rules

# PostgreSQL superuser password (Docker only — not used by cube_api role)
POSTGRES_CUBE_PASSWORD=CHANGE_ME

# ------------------------------------------------------------
# 2D PLANES (n8n + Node.js handlers)
# ------------------------------------------------------------
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME

# Required: n8n encrypts all stored credentials with this key
N8N_ENCRYPTION_KEY=CHANGE_ME_use_openssl_rand_hex_32

# Redis (shared with Cube)
REDIS_URL=redis://localhost:6379

# Google OAuth2 — MUST be Web Application type in Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=CHANGE_ME

# JWT secret for Plane service account tokens sent to Cube
PLANE_TO_CUBE_JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# PostgreSQL for Plane state store (postgres-planes container)
PLANES_DB_URL=postgresql://planes_app:CHANGE_ME@localhost:5434/tesseract_planes
POSTGRES_PLANES_PASSWORD=CHANGE_ME

# ------------------------------------------------------------
# OUTER SPHERE (Next.js 15)
# ------------------------------------------------------------
# WebSocket URL for verdict push channel
NEXT_PUBLIC_WS_URL=ws://localhost:3000/api/ws

# Internal API gateway base URL
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:3000

# Bearer token secret for Sphere → Plane webhook auth
SPHERE_BEARER_TOKEN_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# Anthropic API key for Claude agents
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ------------------------------------------------------------
# MONITORING
# ------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ------------------------------------------------------------
# NOTES
# ------------------------------------------------------------
# 1. Generate secrets: openssl rand -hex 32
# 2. Google OAuth2 MUST use credential type "Web Application" (not Desktop).
#    Redirect URI to register: https://[n8n-host]/rest/oauth2-credential/callback
# 3. mTLS certs: see docs/runbooks/mtls-cert-generation.md (Sprint 1)
# 4. CUBE_RULES_PATH is mounted as a volume from the /rules repo
